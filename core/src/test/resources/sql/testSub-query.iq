!use post
!set outputformat mysql
SELECT deptno
FROM emp AS e
WHERE cast(e.deptno as bigint) in (130, 131, 132, 133, 134);
EnumerableCalc(expr#0=[{inputs}], expr#1=[CAST($t0):BIGINT], expr#2=[Sarg[130L:BIGINT, 131L:BIGINT, 132L:BIGINT, 133L:BIGINT, 134L:BIGINT]:BIGINT], expr#3=[SEARCH($t1, $t2)], DEPTNO=[$t0], $condition=[$t3])
  EnumerableValues(tuples=[[{ 10 }, { 10 }, { 20 }, { 30 }, { 30 }, { 50 }, { 50 }, { 60 }, { null }]])
!plan
